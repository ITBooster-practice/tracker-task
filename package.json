{
	"name": "tracker-task",
	"version": "0.0.0",
	"private": true,
	"description": "",
	"author": "",
	"license": "UNLICENSED",
	"scripts": {
		"dev": "docker compose up redis -d && turbo run dev",
		"build": "turbo run build",
		"test": "docker compose --env-file apps/api/.env.test.local -f docker-compose.test.yml up -d && turbo run test",
		"test:e2e": "docker compose --env-file apps/api/.env.test.local -f docker-compose.test.yml up -d && turbo run test:e2e",
		"lint": "turbo run lint",
		"lint:api": "turbo run lint --filter=api",
		"lint:web": "turbo run lint --filter=web",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"type-check": "turbo run type-check",
		"prepare": "husky || true",
		"docker:redis-up": "docker compose up redis -d",
		"docker:redis-status": "docker ps --filter \"name=redis\"",
		"docker:redis-down": "docker compose down redis",
		"docker:test-up": "docker compose --env-file apps/api/.env.test.local -f docker-compose.test.yml up -d",
		"docker:test-down": "docker compose -f docker-compose.test.yml down",
		"prisma:generate": "turbo run prisma:generate",
		"prisma:migrate": "pnpm --filter api prisma:migrate",
		"prisma:studio": "pnpm --filter api prisma:studio",
		"prisma:seed": "pnpm --filter api prisma:seed",
		"prisma:reset": "pnpm --filter api prisma:migrate reset --force"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"turbo": "^2.8.9",
		"typescript-eslint": "^8.55.0"
	},
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=22"
	}
}
