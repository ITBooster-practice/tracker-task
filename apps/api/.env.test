# Переменные для интеграционных тестов
DATABASE_URL="postgresql://postgres:password@localhost:5433/test_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5433/test_db?schema=public"

# Для docker-compose и инициализации образа Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=test_db
POSTGRES_PORT=5433

# JWT
JWT_SECRET=test_jwt_secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
JWT_REFRESH_SECRET=test_jwt_refresh_secret

# Cookies
COOKIE_DOMAIN=localhost
COOKIES_TTL=7d

# Redis
REDIS_URL=redis://localhost:6379
