# Корневой файл EditorConfig (не искать настройки в родительских папках)
root = true

# Применяется ко всем файлам
[*]
# Тип переноса строки (Unix-стиль)
end_of_line = lf

# Добавлять пустую строку в конце файла
insert_final_newline = true

# Удалять пробелы в конце строк
trim_trailing_whitespace = true

# Кодировка файлов
charset = utf-8

# Использовать табы для отступов
indent_style = tab

# Размер отступа (визуальное отображение табуляции)
indent_size = 2
