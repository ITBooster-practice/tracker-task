# Скопируйте в .env.stage и заполните значения.
# Пример:
# cp .env.stage.example .env.stage

# Базовые репозитории образов для deploy-stage.sh.
# Часть после ':' здесь служебная и будет заменена аргументом скрипта.
# Пример: ./deploy-stage.sh v1.0.0 -> ghcr.io/suvstreet/tracker-web:v1.0.0
API_IMAGE=ghcr.io/<ВАШ_ORG_ИЛИ_USER>/tracker-api:sha-<КРАТКИЙ_SHA_ИЛИ_ТЕГ>
WEB_IMAGE=ghcr.io/<ВАШ_ORG_ИЛИ_USER>/tracker-web:sha-<КРАТКИЙ_SHA_ИЛИ_ТЕГ>

# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
POSTGRES_USER=tracker
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
POSTGRES_PASSWORD=<ВАШ_ПАРОЛЬ_POSTGRES>
POSTGRES_DB=tracker_stage

# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ (должно совпадать с POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB)
DATABASE_URL=postgresql://tracker:<ВАШ_ПАРОЛЬ_POSTGRES>@postgres:5432/tracker_stage
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ (должно совпадать с POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB)
DIRECT_URL=postgresql://tracker:<ВАШ_ПАРОЛЬ_POSTGRES>@postgres:5432/tracker_stage
REDIS_URL=redis://redis:6379

# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
JWT_SECRET=<ВАШ_ДЛИННЫЙ_JWT_SECRET>
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
# Если домена пока нет, временно используйте: stage.<IP_СЕРВЕРА>.sslip.io
COOKIE_DOMAIN=stage.<ВАШ_ДОМЕН>
COOKIES_TTL=604800000
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
WEB_APP_URL=https://stage.<ВАШ_ДОМЕН>
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
NEXT_PUBLIC_API_URL=https://stage.<ВАШ_ДОМЕН>/api

MAIL_TRANSPORT=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
MAIL_FROM=noreply@stage.<ВАШ_ДОМЕН>
# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ
MAIL_FROM_NAME="<НАЗВАНИЕ_ПРОЕКТА_STAGE>"

NEXT_PUBLIC_FEATURE_PROJECTS=true
NEXT_PUBLIC_FEATURE_TASKS=true
NEXT_PUBLIC_FEATURE_TEAM_SETTINGS=true
NEXT_PUBLIC_FEATURE_BOARDS=false
