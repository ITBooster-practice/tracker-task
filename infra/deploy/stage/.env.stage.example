# Скопируйте файл:
# cp .env.stage.example .env.stage

############################
# ОБРАЗЫ (GHCR)
############################

# Базовые репозитории образов.
# Тег будет подставляться автоматически через deploy-stage.sh
API_IMAGE=ghcr.io/<ORG_ИЛИ_USER>/tracker-api:sha-<TAG>
WEB_IMAGE=ghcr.io/<ORG_ИЛИ_USER>/tracker-web:sha-<TAG>

############################
# POSTGRESQL
############################

POSTGRES_USER=tracker
POSTGRES_PASSWORD=<СЛОЖНЫЙ_ПАРОЛЬ>
POSTGRES_DB=tracker_stage

# ВАЖНО:
# используется внутри docker-сети (postgres — это имя сервиса, НЕ localhost)
DATABASE_URL=postgresql://tracker:<СЛОЖНЫЙ_ПАРОЛЬ>@postgres:5432/tracker_stage
DIRECT_URL=postgresql://tracker:<СЛОЖНЫЙ_ПАРОЛЬ>@postgres:5432/tracker_stage

############################
# REDIS
############################

REDIS_URL=redis://redis:6379

############################
# АВТОРИЗАЦИЯ
############################

# Секрет для JWT (должен быть длинным и случайным)
JWT_SECRET=<ДЛИННЫЙ_СЕКРЕТ>

JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

############################
# URL АППЛИКАЦИИ (stage домен)
############################

# Если домена нет:
# stage.<IP_СЕРВЕРА>.sslip.io

COOKIE_DOMAIN=stage.<ВАШ_ДОМЕН>

WEB_APP_URL=https://stage.<ВАШ_ДОМЕН>

# URL, который видит браузер (через Caddy)
NEXT_PUBLIC_API_URL=https://stage.<ВАШ_ДОМЕН>/api

############################
# ПОЧТА (Mailpit)
############################

# SMTP внутри Docker сети
MAIL_TRANSPORT=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025

# От кого отправляются письма
MAIL_FROM=noreply@stage.<ВАШ_ДОМЕН>
MAIL_FROM_NAME="Tracker Stage"

############################
# NEXT_PUBLIC_* для web
############################

# В stage здесь хранится только URL API.
# Feature flags лежат в apps/web/.env.feature-flags
# и при deploy копируются на сервер отдельно.
